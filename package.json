{
  "name": "kit-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @satoshai/kit build",
    "test": "pnpm --filter @satoshai/kit test",
    "test:unit": "pnpm --filter @satoshai/kit test:unit",
    "lint": "eslint packages/*/src/**/*.{ts,tsx}",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.55.0"
  }
}
