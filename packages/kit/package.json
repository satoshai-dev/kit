{
  "name": "@satoshai/kit",
  "version": "1.0.0",
  "description": "Typesafe Stacks wallet & contract interaction library for React",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../README.md ./README.md",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stacks/connect": "8.2.6",
    "bns-v2-sdk": "^2.1.0",
    "clarity-abitype": "^0.4.0"
  },
  "peerDependencies": {
    "@stacks/transactions": ">=7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@stacks/transactions": "^7.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "stacks",
    "wallet",
    "react",
    "hooks",
    "web3",
    "blockchain",
    "bitcoin",
    "clarity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/satoshai-dev/kit"
  },
  "homepage": "https://github.com/satoshai-dev/kit#readme",
  "bugs": {
    "url": "https://github.com/satoshai-dev/kit/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
